{
  "name": "gatherpress-cache-invalidation-hooks",
  "version": "0.3.0",
  "description": "Cache Invalidation system based on event end dates, similar to WordPress scheduled posts, but for GatherPress.",
  "author": "Carsten Bach",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "cache",
    "invalidation",
    "gatherpress",
    "wordpress"
  ],
  "homepage": "https://github.com/carstingaxion/gatherpress-cache-invalidation-hooks#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carstingaxion/gatherpress-cache-invalidation-hooks.git"
  },
  "bugs": {
    "url": "https://github.com/carstingaxion/gatherpress-cache-invalidation-hooks/issues"
  },
  "devDependencies": {
    "@wordpress/env": "^11.2.0",
    "@wordpress/i18n": "^6.15.0",
    "@wordpress/scripts": "^31.7.0"
  },
  "scripts": {
    "check-engines": "wp-scripts check-engines",
    "check-licenses": "wp-scripts check-licenses",
    "i18n:pot": " wp i18n make-pot . --exclude=node_modules,vendor",
    "i18n:json": "wp i18n make-json languages --no-purge",
    "i18n:php": "wp i18n make-php languages",
    "lint:md:docs": "wp-scripts lint-md-docs",
    "lint:md:js": "wp-scripts lint-md-js",
    "lint:php": "vendor/bin/phpcs --standard=.phpcs.xml --extensions=php --colors -s -p -v .",
    "lint:php:fix": "vendor/bin/phpcbf --standard=.phpcs.xml -p -v .",
    "lint:phpstan": "vendor/bin/phpstan analyze -vv --memory-limit=2G",
    "lint:pkg-json": "wp-scripts lint-pkg-json",
    "packages-update": "wp-scripts packages-update",
    "plugin-zip": "wp-scripts plugin-zip",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:destroy": "wp-env destroy",
    "pretest:php": "wp-env start",
    "test:php": "wp-env run tests-cli --env-cwd='wp-content/plugins/gatherpress-cache-invalidation-hooks' bash -c 'WP_TESTS_DIR=/wordpress-phpunit vendor/bin/phpunit'",
    "test:php:unit": "wp-env run tests-cli --env-cwd='wp-content/plugins/gatherpress-cache-invalidation-hooks' bash -c 'WP_TESTS_DIR=/wordpress-phpunit vendor/bin/phpunit --testsuite unit'",
    "test:php:integration": "wp-env run tests-cli --env-cwd='wp-content/plugins/gatherpress-cache-invalidation-hooks' bash -c 'WP_TESTS_DIR=/wordpress-phpunit vendor/bin/phpunit --testsuite integration'"
  }
}
